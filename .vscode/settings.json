{
    // General settings
    "files.autoSave": "onFocusChange",
    "editor.formatOnSave": true, // Apply to all file types
    "editor.rulers": [
        120
    ],
    // Shell Scripts
    "[shellscript]": {
        "editor.defaultFormatter": "mads-hartmann.bash-ide-vscode"
    },
    // Rust settings
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust-analyzer"
    },
    "rust-analyzer.rustfmt.extraArgs": [
        "--config",
        "max_width=120"
    ],
    // Python settings
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.codeActionsOnSave": [
            "source.organizeImports",
            "source.fixAll"
        ]
    },
    "isort.args": [
        "--profile",
        "black"
    ],
    "python.terminal.activateEnvInCurrentTerminal": true, // Authomanically activate vitrual environment
    "black-formatter.args": [
        "--line-length",
        "120"
    ],
    "flake8.args": [
        "--max-line-length=120",
        "--ignore=E501,W503,W504,E203",
        "--max-complexity=10",
        "--exclude=migrations/,settings.py,venv/" // ignore folders migrations/,settings.py,venv/
    ],
    "python.analysis.typeEvaluation.enableReachabilityAnalysis": true,
    "python.analysis.typeEvaluation.strictDictionaryInference": false,
    "python.terminal.useEnvFile": true,
    // Golang settings
    "gopls": {
        "ui.semanticTokens": true
    },
    "[go]": {
        "editor.defaultFormatter": "golang.go"
    },
    // Json setting
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features",
    }
}