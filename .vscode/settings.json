{
    // General settings
    "files.autoSave": "onFocusChange",
    "editor.rulers": [
        120 
    ],
    "editor.linkedEditing": true, 

    // Shell Scripts
    "[shellscript]": { 
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "mads-hartmann.bash-ide-vscode" 
    },

    // Rust settings
    "[rust]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "rust-lang.rust-analyzer"
    },
    "rust-analyzer.rustfmt.extraArgs": ["--config", "max_width=120"],

    // Python settings
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": [
        "source.organizeImports",
        "source.fixAll"]
    },
    "isort.args": [
        "--profile",
        "black"
    ],
    "python.terminal.activateEnvInCurrentTerminal": true, // Authomanically activate vitrual environment
    "black-formatter.args": ["--line-length", "120"],
    "flake8.args": [
        "--max-line-length=120",
        "--ignore=E501,W503,W504,E203",
        "--max-complexity=10",
        "--exclude=migrations/,settings.py,venv/"  // ignore folders migrations/,settings.py,venv/
    ],
    "python.analysis.typeEvaluation.enableReachabilityAnalysis": true,
    "python.analysis.typeEvaluation.strictDictionaryInference": false,
    "python.terminal.useEnvFile":true,
    
}
